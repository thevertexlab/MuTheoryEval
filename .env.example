# LLM API Keys — copy this file to .env and fill in your keys
# .env is gitignored and will never be committed

# OpenAI
OPENAI_API_KEY=sk-...

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Google Gemini
GOOGLE_GEMINI_API_KEY=AIza...

# DeepSeek
DEEPSEEK_API_KEY=sk-...

# DeepInfra (open-weight models: LLaMA, Mistral, Qwen, etc.)
DEEPINFRA_API_KEY=...

# Groq (fast inference for open-weight models)
GROQ_API_KEY=gsk_...

# MiniMax
MINIMAX_API_KEY=...

# HuggingFace (required for WildScore/CMI-Bench lazy image/audio download)
# Get token at: huggingface.co/settings/tokens (read access is enough)
HF_TOKEN=hf_...
